  "formula_versions": [
    {
      "id": 1,
      "formula_id": 1,
      "version": 1,
      "expression_json": "{\"description\":\"Cu base with silver credit\",\"steps\":[{\"name\":\"Cu Recovery Value\",\"expr\":\"Cu * weight * cu_recovery_pct / 100 / 1000\"},{\"name\":\"Ag Credit Value\",\"expr\":\"Ag * weight * ag_content_pct / 100 / 32.15 * 0.9\"},{\"name\":\"Commercial Factor\",\"expr\":\"(Cu_Recovery_Value + Ag_Credit_Value) * 0.985\"},{\"name\":\"Final Value MYR\",\"expr\":\"Commercial_Factor * fx_rate\"}]}",
      "input_variables": "[\"Cu\",\"Ag\",\"weight\",\"cu_recovery_pct\",\"ag_content_pct\",\"fx_rate\"]",
      "output_unit": "MYR",
      "rounding_rule": "round2",
      "tax_rule": null,
      "deduction_rules": "[{\"name\":\"Handling Charge\",\"amount\":50},{\"name\":\"Assay Fee\",\"amount\":150}]",
      "effective_from": "2024-01-01",
      "effective_to": null,
      "created_by": 1,
      "created_at": "2026-04-02T07:32:38.084Z"
    },
    {
      "id": 2,
      "formula_id": 2,
      "version": 1,
      "expression_json": "{\"description\":\"Pd and Au composite pricing\",\"steps\":[{\"name\":\"Pd Value\",\"expr\":\"Pd * weight * pd_recovery_pct / 100 / 32.15\"},{\"name\":\"Au Value\",\"expr\":\"Au * weight * au_recovery_pct / 100 / 32.15\"},{\"name\":\"Ni Deduction\",\"expr\":\"Ni * weight * 0.001\"},{\"name\":\"Gross Value\",\"expr\":\"Pd_Value + Au_Value - Ni_Deduction\"},{\"name\":\"Final Value MYR\",\"expr\":\"Gross_Value * fx_rate\"}]}",
      "input_variables": "[\"Pd\",\"Au\",\"Ni\",\"weight\",\"pd_recovery_pct\",\"au_recovery_pct\",\"fx_rate\"]",
      "output_unit": "MYR",
      "rounding_rule": "round2",
      "tax_rule": null,
      "deduction_rules": "[{\"name\":\"Processing Fee\",\"amount\":200},{\"name\":\"Assay Fee\",\"amount\":250}]",
      "effective_from": "2024-01-01",
